generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  region    String   @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at")

  valueStreams        ValueStream[]
  arts                Art[]
  teams               Team[]
  initiatives         Initiative[]
  kpis                Kpi[]
  epicApprovals       EpicApproval[]
  userRoleAssignments UserRoleAssignment[]
  jiraConfig          JiraConfig?
  azureDevOpsConfig   AzureDevOpsConfig?
  targetModels         TargetOperatingModel[]
  targetOutcomes       TargetOutcome[]
  transformationActions TransformationAction[]
  transformationGoals  TransformationGoal[]
  goalEpicLinks        GoalEpicLink[]

  @@map("tenants")
}

/// The management-defined target operating model — the "Soll" the transformation
/// drives toward. At most one `active` model per tenant (enforced in the
/// service, which archives the prior active on activation). Nullable structure
/// targets and the practice flags express *which* of SAFe the org actually
/// adopts — the flags are the master switch that scopes which concepts appear.
model TargetOperatingModel {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  status     String    @default("draft") // draft | active | archived
  template   String? // team_level | essential_safe | portfolio_safe | custom
  targetDate DateTime? @map("target_date")

  // Structure targets — null = not part of the target.
  targetValueStreams   Int? @map("target_value_streams")
  targetArtsTotal      Int? @map("target_arts_total")
  targetTeamsTotal     Int? @map("target_teams_total")
  targetPiCadenceWeeks Int? @map("target_pi_cadence_weeks")

  // Enabled practices — which parts of the model the org actually runs.
  portfolioLevel     Boolean @default(true) @map("portfolio_level")
  programLevel       Boolean @default(true) @map("program_level")
  stageGates         Boolean @default(true) @map("stage_gates")
  wsjf               Boolean @default(true)
  multiPartyApproval Boolean @default(true) @map("multi_party_approval")
  featureQs          Boolean @default(true) @map("feature_qs")
  dependencies       Boolean @default(true)
  piObjectives       Boolean @default(true) @map("pi_objectives")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @map("created_by") @db.Uuid
  updatedBy String   @map("updated_by") @db.Uuid

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("target_operating_models")
}

/// A management-defined organisation-wide outcome/OKR the transformation targets
/// — the *business* part of the Soll (distinct from Epic-scoped KPIs and
/// PI-scoped Objectives). Tenant-scoped so it survives target-model re-activation.
model TargetOutcome {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  goalId     String?   @map("goal_id") @db.Uuid // KPI of a strategic goal (null = unbound)
  title      String
  metricUnit String?   @map("metric_unit")
  baseline   Float?
  target     Float
  current    Float?
  dueDate    DateTime? @map("due_date")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  createdBy  String    @map("created_by") @db.Uuid
  updatedBy  String    @map("updated_by") @db.Uuid

  tenant Tenant              @relation(fields: [tenantId], references: [id])
  goal   TransformationGoal? @relation(fields: [goalId], references: [id])

  @@index([tenantId])
  @@index([goalId])
  @@map("target_outcomes")
}

/// A strategic transformation goal set by senior management — the direction the
/// transformation drives toward. Measured by KPIs (TargetOutcome rows with this
/// goalId) and realised by Epics (via GoalEpicLink). Managed via `target.manage`.
model TransformationGoal {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  title       String
  description String?   @db.Text
  ownerId     String?   @map("owner_id") @db.Uuid // senior-management owner
  dueDate     DateTime? @map("due_date")
  status      String    @default("active") // active | achieved | archived
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdBy   String    @map("created_by") @db.Uuid
  updatedBy   String    @map("updated_by") @db.Uuid

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  kpis      TargetOutcome[]
  epicLinks GoalEpicLink[]

  @@index([tenantId])
  @@map("transformation_goals")
}

/// Many-to-many link between a strategic goal and an Epic that realises it.
model GoalEpicLink {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  goalId    String   @map("goal_id") @db.Uuid
  epicId    String   @map("epic_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String   @map("created_by") @db.Uuid

  tenant Tenant             @relation(fields: [tenantId], references: [id])
  goal   TransformationGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  epic   Initiative         @relation(fields: [epicId], references: [id])

  @@unique([goalId, epicId])
  @@index([tenantId])
  @@index([epicId])
  @@map("goal_epic_links")
}

/// A tracked transformation action — the "Steuern" backlog that moves the
/// organisation from Ist toward the Soll. Management-owned, tenant-scoped.
model TransformationAction {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  title     String
  status    String    @default("open") // open | in_progress | done
  ownerId   String?   @map("owner_id") @db.Uuid
  dueDate   DateTime? @map("due_date")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String    @map("created_by") @db.Uuid
  updatedBy String    @map("updated_by") @db.Uuid

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("transformation_actions")
}

model ValueStream {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  name           String
  description    String?
  budgetAmount   Decimal? @map("budget_amount") @db.Decimal(14, 2)
  budgetCurrency String?  @map("budget_currency") @db.Char(3)
  // Governance: who signs off Epics in this value stream (Finance party) and the
  // responsible VMO — loose user ids (users live in Supabase auth).
  financeApproverId String? @map("finance_approver_id") @db.Uuid
  vmoId             String? @map("vmo_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")
  deletedAt      DateTime? @map("deleted_at")

  tenant Tenant       @relation(fields: [tenantId], references: [id])
  arts   Art[]
  epics  Initiative[] @relation("EpicValueStream")

  // Uniqueness among *active* (non-deleted) rows is enforced by a partial unique
  // index created out-of-band (see prisma/manual-indexes.sql) — Prisma can't
  // express `WHERE deleted_at IS NULL`, so the table-level @@unique is dropped.
  @@map("value_streams")
}

model Art {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  valueStreamId  String   @map("value_stream_id") @db.Uuid
  name           String
  description    String?
  piCadenceWeeks Int      @default(10) @map("pi_cadence_weeks")
  rteId          String?  @map("rte_id") @db.Uuid // Release Train Engineer
  createdAt      DateTime  @default(now()) @map("created_at")
  deletedAt      DateTime? @map("deleted_at")

  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  valueStream ValueStream        @relation(fields: [valueStreamId], references: [id])
  pis         ProgramIncrement[]
  features    Initiative[]       @relation("FeatureArt")
  teams       Team[]
  impediments Impediment[]

  // Active-row uniqueness via a partial unique index (see prisma/manual-indexes.sql).
  @@map("arts")
}

model Team {
  id             String  @id @default(uuid()) @db.Uuid
  tenantId       String  @map("tenant_id") @db.Uuid
  artId          String  @map("art_id") @db.Uuid
  name           String
  description    String?
  headcount      Int?
  targetVelocity Int?    @map("target_velocity")
  scrumMasterId  String? @map("scrum_master_id") @db.Uuid
  productOwnerId String? @map("product_owner_id") @db.Uuid
  teamType       String? @map("team_type") // stream_aligned | complicated_subsystem | platform | enabling

  tenant     Tenant        @relation(fields: [tenantId], references: [id])
  art        Art           @relation(fields: [artId], references: [id])
  sprints    Sprint[]
  objectives PiObjective[]

  @@unique([tenantId, name])
  @@index([artId])
  @@map("teams")
}

model ProgramIncrement {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  artId     String   @map("art_id") @db.Uuid
  name      String
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  status    String   @default("planned")

  art         Art              @relation(fields: [artId], references: [id])
  sprints     Sprint[]
  initiatives Initiative[]
  objectives  PiObjective[]
  impediments Impediment[]

  @@map("program_increments")
}

model PiObjective {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  piId        String   @map("pi_id") @db.Uuid
  teamId      String   @map("team_id") @db.Uuid
  title       String
  description String?  @db.Text
  businessValue Int?   @map("business_value") // 1-10
  committed   Boolean  @default(true)
  confidence  Int?     @map("confidence") // SAFe fist-of-five vote, 1-5
  createdAt   DateTime @default(now()) @map("created_at")
  createdBy   String   @map("created_by") @db.Uuid

  pi   ProgramIncrement @relation(fields: [piId], references: [id])
  team Team             @relation(fields: [teamId], references: [id])

  @@index([piId])
  @@index([teamId])
  @@map("pi_objectives")
}

model Sprint {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  piId      String   @map("pi_id") @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  indexInPi Int      @map("index_in_pi")
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date

  pi          ProgramIncrement @relation(fields: [piId], references: [id])
  team        Team             @relation(fields: [teamId], references: [id])
  initiatives Initiative[]
  impediments Impediment[]

  @@map("sprints")
}

model Initiative {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  level       Int // 0=EPIC, 1=FEATURE, 2=STORY, 3=TASK
  parentId    String? @map("parent_id") @db.Uuid
  path        String // materialized path

  title       String
  description String?  @db.Text
  ownerId     String   @map("owner_id") @db.Uuid
  assigneeIds String[] @map("assignee_ids") @db.Uuid

  // Level-specific foreign keys
  valueStreamId String? @map("value_stream_id") @db.Uuid // EPIC only
  artId         String? @map("art_id") @db.Uuid // FEATURE only
  piId          String? @map("pi_id") @db.Uuid // FEATURE, STORY
  sprintId      String? @map("sprint_id") @db.Uuid // STORY only

  // WSJF fields (FEATURE only)
  wsjfBusinessValue   Int?     @map("wsjf_business_value")
  wsjfTimeCriticality Int?     @map("wsjf_time_criticality")
  wsjfRiskReduction   Int?     @map("wsjf_risk_reduction")
  wsjfJobSize         Int?     @map("wsjf_job_size")
  wsjfComputed        Decimal? @map("wsjf_computed") @db.Decimal(5, 2)

  // Epic artefacts (EPIC only – stored as versioned JSON)
  benefitHypothesis Json? @map("benefit_hypothesis") // L1 Reviewing
  businessCase      Json? @map("business_case") // L2 Analyzing

  // Snapshot of the last approved revision's artefacts (EPIC only), captured at
  // startRevision — the baseline the side-by-side revision diff compares against.
  baselineBenefitHypothesis Json? @map("baseline_benefit_hypothesis")
  baselineBusinessCase      Json? @map("baseline_business_case")

  // Epic timeline (EPIC only): owner-set estimates + manual actuals (backlog,
  // implementation) as a flat JSON; auto actuals live in the columns below.
  timeline               Json?     @map("timeline")
  hypothesisApprovedAt   DateTime? @map("hypothesis_approved_at")
  businessCaseApprovedAt DateTime? @map("business_case_approved_at")

  // Story points (STORY only)
  storyPoints Int? @map("story_points")

  // Acceptance criteria (FEATURE, STORY)
  acceptanceCriteria String[] @map("acceptance_criteria")

  // Task estimate (TASK only)
  estimateHours Decimal? @map("estimate_hours") @db.Decimal(5, 1)

  // External system sync (e.g. Jira issue key "PROJ-123")
  externalId     String? @map("external_id")
  externalSystem String? @map("external_system") // "jira" | "ado"

  stageGate String @default("L0") @map("stage_gate")
  status    String @default("draft")

  // Multi-party approval workflow phase (EPIC only): draft → hypothesis_review →
  // business_case → stakeholder_review → approved. Independent of stageGate.
  approvalPhase String? @map("approval_phase")
  // Active approval revision (EPIC only). Bumped each time a new approval cycle
  // is started on an already-approved Epic; EpicApproval rows are tagged with it.
  approvalRevision Int @default(1) @map("approval_revision")

  // Epic approval metadata (set when an Epic is approved)
  approvedBy      String?   @map("approved_by") @db.Uuid
  approvedAt      DateTime? @map("approved_at")
  approvalComment String?   @map("approval_comment") @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String    @map("created_by") @db.Uuid
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String    @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at")

  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  parent      Initiative?       @relation("Hierarchy", fields: [parentId], references: [id])
  children    Initiative[]      @relation("Hierarchy")
  valueStream ValueStream?      @relation("EpicValueStream", fields: [valueStreamId], references: [id])
  art         Art?              @relation("FeatureArt", fields: [artId], references: [id])
  pi          ProgramIncrement? @relation(fields: [piId], references: [id])
  sprint      Sprint?           @relation(fields: [sprintId], references: [id])

  dependenciesOut Dependency[] @relation("From")
  dependenciesIn  Dependency[] @relation("To")
  kpis            Kpi[]
  epicApprovals   EpicApproval[]
  goalLinks       GoalEpicLink[]

  @@index([tenantId])
  @@index([parentId])
  @@index([piId])
  @@index([ownerId, status])
  @@index([path])
  @@map("initiatives")
}

model EpicApproval {
  id           String @id @default(uuid()) @db.Uuid
  tenantId     String @map("tenant_id") @db.Uuid
  initiativeId String @map("initiative_id") @db.Uuid

  revision       Int     @default(1) // approval cycle this row belongs to
  kind           String // "party" | "section"
  party          String? // ApprovalParty (kind=party): mgmt | business_owner | finance | irt_owner | lace_vmo
  section        String? // kind=section: "breakdown" | "kpis"
  approverUserId String? @map("approver_user_id") @db.Uuid // assigned approver (party) / reviewer (section)

  status      String    @default("pending") // pending | approved | rejected
  decidedAt   DateTime? @map("decided_at")
  comment     String?   @db.Text
  requestedAt DateTime  @default(now()) @map("requested_at")
  createdBy   String    @map("created_by") @db.Uuid

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  initiative Initiative @relation(fields: [initiativeId], references: [id])

  @@index([tenantId, initiativeId, revision])
  @@index([approverUserId, status])
  @@map("epic_approvals")
}

model Kpi {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  initiativeId String   @map("initiative_id") @db.Uuid
  name         String
  unit         String?
  baseline     Decimal? @db.Decimal(14, 2)
  target       Decimal? @db.Decimal(14, 2)
  measurements Json // [{ date: ISO, value: number }] — time series of actuals

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String   @map("created_by") @db.Uuid
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String   @map("updated_by") @db.Uuid

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  initiative Initiative @relation(fields: [initiativeId], references: [id])

  @@index([tenantId, initiativeId])
  @@map("kpis")
}

model Dependency {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  fromId    String   @map("from_id") @db.Uuid
  toId      String   @map("to_id") @db.Uuid
  type      String // 'blocks' | 'depends_on' | 'relates_to'
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String   @map("created_by") @db.Uuid

  from Initiative @relation("From", fields: [fromId], references: [id])
  to   Initiative @relation("To", fields: [toId], references: [id])

  @@unique([fromId, toId, type])
  @@map("dependencies")
}

model AuditEvent {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  occurredAt   DateTime @default(now()) @map("occurred_at")
  actorId      String   @map("actor_id") @db.Uuid
  action       String
  resourceType String   @map("resource_type")
  resourceId   String   @map("resource_id") @db.Uuid
  changes      Json?
  ipAddress    String?  @map("ip_address") @db.Inet
  userAgent    String?  @map("user_agent")
  traceId      String?  @map("trace_id")

  @@index([tenantId, occurredAt(sort: Desc)])
  @@index([resourceType, resourceId, occurredAt(sort: Desc)])
  @@map("audit_events")
}

model UserRoleAssignment {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  role           String
  valueStreamIds String[] @map("value_stream_ids") @db.Uuid
  artIds         String[] @map("art_ids") @db.Uuid
  teamIds        String[] @map("team_ids") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([userId, tenantId, role])
  @@map("user_role_assignments")
}

model Impediment {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  artId       String    @map("art_id") @db.Uuid
  piId        String?   @map("pi_id") @db.Uuid
  sprintId    String?   @map("sprint_id") @db.Uuid
  title       String
  description String?   @db.Text
  severity    String    @default("medium") // low | medium | high | critical
  status      String    @default("open")   // open | escalated | resolved
  raisedBy    String    @map("raised_by") @db.Uuid
  resolvedAt  DateTime? @map("resolved_at")
  resolvedBy  String?   @map("resolved_by") @db.Uuid
  resolution  String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  art    Art              @relation(fields: [artId], references: [id])
  pi     ProgramIncrement? @relation(fields: [piId], references: [id])
  sprint Sprint?           @relation(fields: [sprintId], references: [id])

  @@index([artId, status])
  @@index([piId])
  @@map("impediments")
}

model JiraConfig {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @unique @map("tenant_id") @db.Uuid
  cloudId        String    @map("cloud_id") // Atlassian cloud ID
  instanceUrl    String    @map("instance_url") // https://yoursite.atlassian.net
  accessToken    String    @map("access_token") @db.Text
  refreshToken   String    @map("refresh_token") @db.Text
  tokenExpiresAt DateTime  @map("token_expires_at")
  // projectKey: JSON map of artId → Jira project key, e.g. {"<artId>": "PROJ"}
  projectKeyMap  Json      @default("{}") @map("project_key_map")
  webhookSecret  String    @map("webhook_secret") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("jira_configs")
}

model AzureDevOpsConfig {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @unique @map("tenant_id") @db.Uuid
  organization   String    // e.g. "my-org"
  accessToken    String    @map("access_token") @db.Text
  refreshToken   String    @map("refresh_token") @db.Text
  tokenExpiresAt DateTime  @map("token_expires_at")
  // projectMap: JSON map of artId → "Organization/Project", e.g. {"<artId>": "myorg/MyProject"}
  projectMap     Json      @default("{}") @map("project_map")
  webhookSecret  String    @map("webhook_secret") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("azure_devops_configs")
}

model OutboxEvent {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  type        String
  payload     Json
  status      String    @default("pending") // pending | processed | failed
  attempts    Int       @default(0)
  lastError   String?   @map("last_error")
  createdAt   DateTime  @default(now()) @map("created_at")
  processedAt DateTime? @map("processed_at")

  @@index([status, createdAt])
  @@map("outbox_events")
}

model IdempotencyKey {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  key            String
  requestHash    String   @map("request_hash")
  responseStatus Int      @map("response_status")
  responseBody   String   @map("response_body") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([tenantId, key])
  @@map("idempotency_keys")
}
