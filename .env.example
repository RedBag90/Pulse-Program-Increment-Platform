# =============================================================================
# Pulse — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Supabase)
# Find these in: Supabase Dashboard → Project → Settings → Database → Connection string
# -----------------------------------------------------------------------------

# Pooled connection string (use for the app — works with serverless/edge)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection string (use for Prisma migrations only)
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# Supabase Auth
# Find these in: Supabase Dashboard → Project → Settings → API
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL="https://[your-project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[your-anon-key]"

# Service role key — server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY="[your-service-role-key]"

# JWT secret for verifying Supabase tokens server-side
SUPABASE_JWT_SECRET="[your-jwt-secret]"

# -----------------------------------------------------------------------------
# Observability (Sentry)
# Create a project at https://sentry.io → Settings → Projects → DSN
# -----------------------------------------------------------------------------

SENTRY_DSN="https://[key]@[org].ingest.sentry.io/[project-id]"
SENTRY_ORG="[your-sentry-org]"
SENTRY_PROJECT="pulse"
NEXT_PUBLIC_SENTRY_DSN="https://[key]@[org].ingest.sentry.io/[project-id]"

# -----------------------------------------------------------------------------
# Email (Resend — recommended) or SMTP
# Create an API key at https://resend.com → API Keys
# -----------------------------------------------------------------------------

# Option A: Resend
RESEND_API_KEY="re_[your-resend-api-key]"
EMAIL_FROM="Pulse <noreply@yourdomain.com>"

# Option B: SMTP (leave blank if using Resend)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@yourdomain.com"
SMTP_PASS="[your-smtp-password]"
SMTP_FROM="Pulse <noreply@yourdomain.com>"

# -----------------------------------------------------------------------------
# Invitations
# Random 32-byte hex string: openssl rand -hex 32
# -----------------------------------------------------------------------------

INVITE_JWT_SECRET="[generate-with-openssl-rand-hex-32]"

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# -----------------------------------------------------------------------------
# Cron (Vercel)
# Set in Vercel Dashboard → Project → Settings → Environment Variables.
# Generate with: openssl rand -hex 32
# Vercel automatically sends this as Authorization: Bearer <secret>
# -----------------------------------------------------------------------------

CRON_SECRET="[generate-with-openssl-rand-hex-32]"

# -----------------------------------------------------------------------------
# Jira Cloud Integration (PULSE-41)
# Create an OAuth 2.0 app at: https://developer.atlassian.com/console/myapps/
# Callback URL must match JIRA_REDIRECT_URI exactly.
# -----------------------------------------------------------------------------

JIRA_CLIENT_ID="[your-jira-oauth-client-id]"
JIRA_CLIENT_SECRET="[your-jira-oauth-client-secret]"
JIRA_REDIRECT_URI="http://localhost:3000/api/integrations/jira/callback"
